{
  "name": "@local/esse-plugin",
  "version": "0.2.4",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "selftest": "npm run selftest:adapter && npm run selftest:core",
    "selftest:adapter": "node mcp/server.cjs --self-test",
    "selftest:core": "node mcp/core.cjs --self-test",
    "smoke:stdio": "node scripts/smoke-stdio.mjs",
    "smoke:multi-stdio": "node scripts/smoke-multi-stdio.mjs",
    "smoke:core-survival": "node scripts/smoke-core-survival.mjs",
    "smoke:core-crash": "node scripts/smoke-core-crash.mjs",
    "e2e:windows": "node scripts/e2e-windows-install.mjs",
    "benchmark:thumbnails": "tsx scripts/benchmark-thumbnails.ts",
    "preview": "node scripts/preview-server.mjs",
    "package:releases": "npm run build && node scripts/package-releases.mjs && node scripts/create-release-metadata.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "check": "npm run typecheck && npm test && npm run build && npm run selftest && npm run smoke:stdio && npm run smoke:multi-stdio && npm run smoke:core-survival && npm run smoke:core-crash && npm run verify:release",
    "start:stdio": "node mcp/server.cjs"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.20.2",
    "@phosphor-icons/react": "^2.1.10",
    "ipaddr.js": "^2.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "esbuild": "^0.25.5",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
