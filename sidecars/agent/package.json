{
  "name": "@esse/community-sidecar",
  "productName": "Esse Community",
  "version": "0.3.1",
  "description": "Esse local image workspace and Agent harness integration",
  "main": ".vite/build/main.js",
  "private": false,
  "scripts": {
    "start": "electron-forge start",
    "build:icons": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-app-icons.ps1",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:macos:arm64": "electron-forge make --platform=darwin --arch=arm64",
    "make:macos:x64": "electron-forge make --platform=darwin --arch=x64",
    "stage:release": "node scripts/stage-release.mjs",
    "publish": "electron-forge publish",
    "smoke": "tsx scripts/smoke.ts",
    "verify:signatures": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-windows-signatures.ps1",
    "verify:icons:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-windows-icons.ps1",
    "verify:package:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-windows-package.ps1",
    "verify:macos": "bash scripts/verify-macos-bundle.sh",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "Renoir",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@electron/windows-sign": "^1.2.2",
    "@eslint/js": "^10.0.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/express": "^5.0.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "43.1.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^5.4.21",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "electron-squirrel-startup": "^1.0.1",
    "express": "^5.2.1",
    "ipaddr.js": "^2.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  }
}
