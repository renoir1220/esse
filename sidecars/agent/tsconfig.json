{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "allowJs": false,
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "outDir": "dist",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "strict": true,
    "types": ["node", "vite/client"]
  },
  "include": ["src", "scripts", "forge.config.ts", "forge.env.d.ts", "vite.*.config.ts", "vite.*.config.mts"]
}
